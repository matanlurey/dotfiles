// Dev layout: tabs for each workflow, full screen for everything
//
// Tab "code":   nvim (full screen, no args — use file picker to navigate)
// Tab "pi":     pi (full screen)
// Tab "jj":     lazyjj (full screen)
// Tab "agents": herdr (full screen)
// Tab "term":   shell (full screen)

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="code" focus=true {
        pane command="nvim" borderless=true
    }

    tab name="pi" {
        pane command="pi" borderless=true
    }

    tab name="jj" {
        pane command="lazyjj" borderless=true
    }

    tab name="agents" {
        pane command="herdr" borderless=true
    }

    tab name="term" {
        pane borderless=true
    }
}
