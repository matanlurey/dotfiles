// MBP layout: same tools as uw, spread across tabs for smaller screens
//
// Tab "code":   nvim (full screen)
// Tab "review": hunk diff (full screen)
// Tab "term":   shell (full screen)
// Use Alt+f for a floating terminal (quake mode)

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="code" focus=true {
        pane command="nvim" borderless=true
    }

    tab name="review" {
        pane command="hunk" borderless=true {
            args "diff"
        }
    }

    tab name="term" {
        pane borderless=true
    }

}
