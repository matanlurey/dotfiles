// Ultra-wide layout: single tab, no tab bar
//
// Top row (left to right): terminal | terminal | terminal
// Bottom: full-width terminal

layout {
    tab name="uw" focus=true {
        pane split_direction="horizontal" {
            pane split_direction="vertical" {
                pane borderless=true focus=true
                pane borderless=true
                pane borderless=true
            }
            pane size="25%" borderless=true
        }
    }
}
