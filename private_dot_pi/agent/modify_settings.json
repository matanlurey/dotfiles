#!/bin/bash
# Merge desired settings into the existing file, preserving runtime keys
# (e.g. lastChangelogVersion that pi updates automatically).
# stdin = current file contents (empty string on first run)

set -euo pipefail

CURRENT="$(cat)"

# Desired settings — edit these when you change preferences
DESIRED='{
  "defaultProvider": "google",
  "defaultModel": "google/gemini-2.5-flash-lite",
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "low",
  "enabledModels": [
    "google/gemini-2.5-flash",
    "google/gemini-2.5-flash-lite",
    "google/gemini-3.1-pro-preview",
    "ollama/qwen3.6:27b"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:@burneikis/pi-fzfp",
    "https://github.com/carderne/pi-nvim",
    "https://github.com/mitsuhiko/pi-draw",
    "npm:pi-autoresearch",
    "npm:pi-interview",
    "npm:pi-subagents",
    "npm:pi-code-previews",
    "npm:pi-intercom",
    "npm:@noahsaso/pi-remote",
    "npm:pi-agent-browser-native",
    "https://github.com/nicobailon/pi-boomerang",
    "npm:@0xkobold/pi-ollama",
    "https://github.com/devnazim/pi-cmux"
  ]
}'

if [ -z "$CURRENT" ]; then
  # First run — no existing file, just output desired
  echo "$DESIRED" | jq .
else
  # Merge: desired keys win, but existing runtime keys are preserved
  echo "$CURRENT" | jq --argjson desired "$DESIRED" '. * $desired'
fi
