#!/bin/bash
# Vast work overlay: Anthropic models via proxy, overrides public dotfiles.
# stdin = current file contents (empty string on first run)

set -euo pipefail

CURRENT="$(cat)"

DESIRED='{
  "defaultProvider": "commandcode",
  "defaultModel": "deepseek/deepseek-v4-flash",
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "low",
  "enabledModels": [
    "commandcode/deepseek/deepseek-v4-flash",
    "commandcode/deepseek/deepseek-v4-pro",
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-opus-4-6"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:@burneikis/pi-fzfp",
    "https://github.com/carderne/pi-nvim",
    "https://github.com/mitsuhiko/pi-draw",
    "npm:pi-autoresearch",
    "npm:pi-interview",
    "npm:pi-subagents",
    "npm:pi-code-previews",
    "npm:pi-intercom",
    "npm:@noahsaso/pi-remote",
    "npm:pi-agent-browser-native",
    "https://github.com/nicobailon/pi-boomerang",
    "npm:pi-commandcode-provider",
    "https://github.com/devnazim/pi-cmux",
    "npm:@gotgenes/pi-anthropic-auth"
  ]
}'

if [ -z "$CURRENT" ]; then
  MERGED="$(echo "$DESIRED" | jq .)"
else
  # Merge: desired keys win, but existing runtime keys (e.g. lastChangelogVersion) are preserved
  MERGED="$(echo "$CURRENT" | jq --argjson desired "$DESIRED" '. * $desired')"
fi

# Add Hunk review skill if hunk is installed (portable across machines / install prefixes)
if command -v hunk >/dev/null 2>&1; then
  HUNK_SKILL_DIR="$(dirname "$(hunk skill path 2>/dev/null)")"
  if [ -n "$HUNK_SKILL_DIR" ] && [ -d "$HUNK_SKILL_DIR" ]; then
    MERGED="$(echo "$MERGED" | jq --arg path "$HUNK_SKILL_DIR" '.skills = ((.skills // []) + [$path] | unique)')"
  fi
fi

echo "$MERGED"
