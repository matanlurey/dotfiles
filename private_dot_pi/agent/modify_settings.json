#!/bin/bash
# Vast work overlay: Anthropic models via proxy, overrides public dotfiles.
# stdin = current file contents (empty string on first run)

set -euo pipefail

CURRENT="$(cat)"

DESIRED='{
  "defaultProvider": "google",
  "defaultModel": "google/gemini-2.5-flash-lite",
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "low",
  "enabledModels": [
    "google/gemini-flash-latest",
    "google/gemini-flash-lite-latest",
    "deepseek/deepseek-v4-flash",
    "deepseek/deepseek-v4-pro",
    "oc-sdk-go/kimi-k2.6"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:@burneikis/pi-fzfp",
    "https://github.com/carderne/pi-nvim",
    "https://github.com/mitsuhiko/pi-draw",
    "npm:pi-autoresearch",
    "npm:pi-interview",
    "npm:pi-subagents",
    "npm:pi-code-previews",
    "npm:pi-intercom",
    "npm:@noahsaso/pi-remote",
    "npm:pi-agent-browser-native",
    "https://github.com/nicobailon/pi-boomerang",
    "npm:pi-commandcode-provider",
    "https://github.com/devnazim/pi-cmux",
    "git:https://github.com/awtotty/pi-opencode.git"
  ]
}'

if [ -z "$CURRENT" ]; then
  echo "$DESIRED" | jq .
else
  # Merge: desired keys win, but existing runtime keys (e.g. lastChangelogVersion) are preserved
  echo "$CURRENT" | jq --argjson desired "$DESIRED" '. * $desired'
fi
